generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
}

enum UserStatus {
  INIT
  PENDING_EMAIL_VERIFICATION
  EMAIL_VERIFIED
  PENDING_ADMIN_APPROVAL
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TokenType {
  ACCESS
  REFRESH
}

enum AuthProvider {
  LOCAL
  EMAIL
  GOOGLE
  FACEBOOK
  APPLE
}

enum NotificationType {
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  NEW_CONNECTION
  QR_SCANNED
  NEW_MESSAGE
  NEW_CHAT_MESSAGE
  APPOINTMENT_BOOKED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELLED
  PAYMENT_COMPLETED
  PRESCRIPTION_RENEWAL_REQUEST
  PRESCRIPTION_EXPIRY_WARNING
  NEW_PRESCRIPTION
}

enum ConnectionStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum RecordType {
  LAB_RESULT
  XRAY
  SCAN
  MEDICAL_REPORT
  VACCINATION
  OTHER
}

enum ConnectionType {
  SCANNED
  REQUESTED
  QR_CODE
  ADMIN_ADDED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  IN_CLINIC
  REMOTE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ==================== CORE MODELS ====================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  firstName String
  lastName  String
  phone     String?
  role      UserRole @default(PATIENT)

  status            UserStatus
  isActive          Boolean      @default(false)
  approvedAt        DateTime?
  approvedBy        String?
  rejectionReason   String?
  isProfileComplete Boolean      @default(false)
  registrationStep  Int          @default(0)
  authProvider      AuthProvider @default(LOCAL)
  providerId        String?
  profilePhoto      String?
  timezone          String?      @default("Africa/Cairo")

  nationalId  String? @unique
  idCardImage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient       Patient?
  doctor        Doctor?
  otps          Otp[]
  tokens        AuthToken[]
  notifications Notification[]
  sendMessages  Message[]

  @@index([status])
  @@index([isActive])
  @@map("users")
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
}

model AuthToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  type      TokenType
  isRevoked Boolean   @default(false)
  createdAt DateTime  @default(now())
  expiresAt DateTime

  userAgent  String?
  deviceName String?
  ipAddress  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_tokens")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  message   String
  type      NotificationType @default(CONNECTION_REQUEST)
  title     String
  metadata  Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, isRead])
  @@map("notifications")
}

model Patient {
  id     String @id @default(uuid())
  userId String @unique

  profilePhoto String?
  dateOfBirth  DateTime?
  gender       String?
  bloodType    String?
  height       Float?
  weight       Float?

  phone       String?
  address     String?
  city        String?
  governorate String?

  allergies             String?
  chronicDiseases       String?
  currentMedications    String?
  emergencyContactName  String?
  emergencyContactPhone String?
  insuranceProvider     String?
  insuranceNumber       String?

  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  connections      DoctorPatientConnection[]
  followUpRequests FollowUpRequest[]
  qrTokens         QrToken[]
  appointments     Appointment[]
  medicalRecords   MedicalRecord[]
  prescriptions    Prescription[]

  @@index([userId])
  @@map("patients")
}

model Specialization {
  id          String  @id @default(uuid())
  name        String  @unique
  nameAr      String?
  description String?

  doctors Doctor[]

  @@map("specializations")
}

model Doctor {
  id               String  @id @default(uuid())
  userId           String  @unique
  specializationId String?

  licenseNumber     String? @unique
  yearsOfExperience Int?
  bio               String?
  rating            Float?  @default(0)
  reviewCount       Int     @default(0)
  education         String?

  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization   Specialization?           @relation(fields: [specializationId], references: [id])
  qrTokens         QrToken[]
  connections      DoctorPatientConnection[]
  followUpRequests FollowUpRequest[]
  prescriptions    Prescription[]
  appointments     Appointment[]
  availabilities   DoctorAvailability[]
  breaks           DoctorBreak[]
  daysOff          DoctorDayOff[]
  medicalRecords   MedicalRecord[]

  @@map("doctors")
}

model DoctorPatientConnection {
  id             String           @id @default(uuid())
  doctorId       String
  patientId      String
  connectionType ConnectionType?
  status         ConnectionStatus @default(ACTIVE)

  connectedAt    DateTime  @default(now())
  lastActivityAt DateTime?
  lastMessageAt  DateTime?
  unreadCount    Int?

  prescriptions  Prescription[]
  doctor         Doctor          @relation(fields: [doctorId], references: [id])
  patient        Patient         @relation(fields: [patientId], references: [id])
  chat           Chat?
  appointments   Appointment[]
  medicalRecords MedicalRecord[]

  @@unique([doctorId, patientId])
  @@index([doctorId])
  @@index([patientId])
  @@index([status])
  @@map("doctor_patient_connections")
}

model FollowUpRequest {
  id        String @id @default(uuid())
  patientId String
  doctorId  String

  prescriptionImage String
  notes             String?
  status            RequestStatus @default(PENDING)
  rejectionReason   String?

  requestDate  DateTime  @default(now())
  responseDate DateTime?
  respondedBy  String?

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])

  @@map("follow_up_requests")
}

model MedicalRecord {
  id           String  @id @default(uuid())
  patientId    String?
  doctorId     String?
  connectionId String? // المتعلق بأي connection

  // File Info
  fileName String // Original filename
  fileUrl  String // Storage URL/path
  fileType RecordType // X_RAY, LAB_RESULT, PRESCRIPTION, etc.
  fileSize Int // in bytes
  mimeType String // image/jpeg, application/pdf, etc.

  // Medical Info
  title       String
  description String?
  treatment   String?
  medications String?
  uploadedBy  String // USER_ID (patient or doctor)
  // Status
  isVerified  Boolean @default(false) // Doctor verified
  notes       String? // Doctor's notes on the file

  // File attachments
  attachments Json?

  recordDate DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  patient    Patient?                 @relation(fields: [patientId], references: [id])
  doctor     Doctor?                  @relation(fields: [doctorId], references: [id])
  connection DoctorPatientConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([doctorId])
  @@index([connectionId])
  @@index([createdAt])
  @@index([recordDate])
}

model Prescription {
  id           String @id @default(uuid())
  connectionId String
  doctorId     String
  patientId    String
  medications  Json // Array of medications

  notes    String?
  isActive Boolean @default(true)

  prescribedAt DateTime
  updateAt     DateTime

  //relation

  connection DoctorPatientConnection @relation(fields: [connectionId], references: [id])
  doctor     Doctor                  @relation(fields: [doctorId], references: [id])
  patient    Patient                 @relation(fields: [patientId], references: [id])

  @@index([isActive])
  @@index([prescribedAt])
  @@map("prescriptions")
}

model QrToken {
  id        String    @id @default(uuid())
  doctorId  String
  token     String    @unique
  type      String    @default("CONNECTION")
  expiresAt DateTime
  isUsed    Boolean   @default(false)
  usedBy    String?
  usedAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  doctor  Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient? @relation(fields: [usedBy], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([doctorId])
  @@index([expiresAt])
  @@map("qr_tokens")
}

model Chat {
  id           String @id @default(uuid())
  connectionId String @unique

  lastMessageAt      DateTime?
  lastMessagePreview String?   @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  connection DoctorPatientConnection @relation(fields: [connectionId], references: [id])
  messages   Message[]

  @@index([connectionId])
  @@index([lastMessageAt])
  @@map("chats")
}

model Message {
  id       String @id @default(uuid())
  chatId   String
  senderId String

  content     String @db.Text
  messageType String @default("TEXT")

  isRead Boolean   @default(false)
  readAt DateTime?

  senderName   String?
  senderRole   String?
  senderAvatar String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chat   Chat @relation(fields: [chatId], references: [id])
  sender User @relation(fields: [senderId], references: [id])

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
  @@index([isRead])
  @@map("messages")
}

// ==================== PHASE 2 - APPOINTMENT SYSTEM ====================

model DoctorAvailability {
  id       String @id @default(uuid())
  doctorId String

  dayOfWeek             DayOfWeek
  startTime             Int // Minutes since midnight (0-1440)
  endTime               Int // Minutes since midnight (0-1440)
  slotDuration          Int       @default(30) // in minutes
  maxAppointmentsPerDay Int       @default(10)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek, startTime, endTime])
  @@index([doctorId])
  @@index([dayOfWeek])
  @@map("doctor_availability")
}

model DoctorBreak {
  id       String @id @default(uuid())
  doctorId String

  dayOfWeek DayOfWeek
  startTime Int // Minutes since midnight
  endTime   Int // Minutes since midnight
  reason    String? // e.g., "Lunch break", "Prayer time"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([dayOfWeek])
  @@map("doctor_breaks")
}

model DoctorDayOff {
  id       String @id @default(uuid())
  doctorId String

  date   DateTime // Specific date when doctor is off
  reason String? // e.g., "Conference", "Medical Leave"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, date])
  @@index([doctorId])
  @@map("doctor_days_off")
}

model Appointment {
  id           String @id @default(uuid())
  doctorId     String
  patientId    String
  connectionId String

  type   AppointmentType   @default(IN_CLINIC)
  status AppointmentStatus @default(PENDING)
  reason String?
  notes  String?

  startTime DateTime
  endTime   DateTime

  clinicId    String?
  roomNumber  String?
  meetingLink String?

  isReminderSent24h Boolean @default(false)
  isReminderSent1h  Boolean @default(false)

  prescriptionId String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?

  doctor     Doctor                  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient    Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  connection DoctorPatientConnection @relation(fields: [connectionId], references: [id])

  @@unique([doctorId, startTime])
  @@index([doctorId])
  @@index([patientId])
  @@index([connectionId])
  @@index([startTime])
  @@index([status])
  @@index([status, startTime])
  @@map("appointments")
}
